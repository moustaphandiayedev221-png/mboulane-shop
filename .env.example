# Copier vers .env.local — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Uniquement côté serveur (jamais exposé au navigateur)
SUPABASE_SERVICE_ROLE_KEY=

# URL canonique (Open Graph, sitemap) — en preview ex. https://xxx.vercel.app
NEXT_PUBLIC_SITE_URL=

# npm run db:migrate — mot de passe base (Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD=
# ou directement : DATABASE_URL=postgresql://...

# Rate limiting partagé multi-instances (optionnel, recommandé en prod)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Admin Supabase Auth : emails autorisés (séparés par des virgules). Vide = admin désactivé.
# ADMIN_EMAILS=

# PayTech (paiement en ligne)
# PAYTECH_API_KEY=
# PAYTECH_API_SECRET=
# PAYTECH_ENV=test
# URL IPN publique (HTTPS) : https://ton-domaine.com/api/paytech/ipn
# PAYTECH_IPN_URL=

# Optionnel : même valeur en header X-Catalog-Key ou Authorization Bearer pour lever le quota /api/catalog.
# CATALOG_API_KEY=

# Erreurs côté client / serveur (optionnel) — https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=
